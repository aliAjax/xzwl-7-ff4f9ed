{
  "name": "ancient-book-restoration",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:check": "tsc --noEmit && vite build",
    "lint": "tsc --noEmit",
    "ci": "npm run typecheck && npm run test && npm run build:check"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^4.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^4.1.8"
  }
}
